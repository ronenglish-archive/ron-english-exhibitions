    }

    .entry{
      display:block;
      border:1px solid var(--border);
      border-radius:var(--radius);
      overflow:hidden;
      box-shadow:var(--shadow);
      text-decoration:none;
      color:inherit;
      background:#fff;
      transition:transform .12s ease, box-shadow .12s ease;
    }

    .entry:hover{
      transform:translateY(-2px);
      box-shadow:0 16px 40px rgba(0,0,0,.12);
    }

    .entry img{
      width:100%;
      height:240px;
      object-fit:cover;
      display:block;
      background:#f3f4f6;
    }

    .entry-body{
      padding:18px 18px 20px;
    }

    .eyebrow{
      display:inline-block;
      margin-bottom:8px;
      font-size:12px;
      font-weight:700;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:#6b7280;
    }

    .entry h2{
      margin:0 0 8px;
      font-size:24px;
      line-height:1.15;
    }

    .entry p{
      margin:0;
      color:var(--muted);
      font-size:16px;
      line-height:1.6;
      max-width:58ch;
    }

    .cta{
      margin-top:14px;
      display:flex;
      align-items:center;
      gap:10px;
      font-weight:650;
      color:#111;
    }

    .dot{
      width:10px;
      height:10px;
      border-radius:999px;
      background:#111;
      display:inline-block;
      flex:0 0 auto;
    }

    .notes{
      margin-top:28px;
      padding-top:18px;
      border-top:1px solid var(--border);
      color:var(--muted);
      font-size:15px;
      line-height:1.65;
    }

    footer{
      margin-top:30px;
      padding-top:16px;
      border-top:1px solid var(--border);
      color:var(--muted);
      font-size:14px;
    }

    @media (max-width:900px){
      .entry-grid{
        grid-template-columns:1fr;
      }

      .entry img{
        height:220px;
      }
    }
  </style>
</head>

