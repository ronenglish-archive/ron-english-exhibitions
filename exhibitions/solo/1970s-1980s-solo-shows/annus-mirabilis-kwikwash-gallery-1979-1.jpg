<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Showflaps / Billboards — Ron English Indoors Outdoors | Ron English Catalogue Raisonné</title>

  <link rel="stylesheet" href="../../css/styles.css" />

  <style>
    :root{
      --border:#e5e7eb;
      --muted:#4b5563;
      --shadow:0 10px 30px rgba(0,0,0,.08);
      --radius:18px;
      --bg:#ffffff;
      --panel:#f8fafc;
    }

    *{
      box-sizing:border-box;
    }

    body{
      margin:0;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
      color:#111;
      background:var(--bg);
    }

    .wrap{
      max-width:1000px;
      margin:0 auto;
      padding:28px 18px 60px;
    }

    .nav-pills{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-bottom:22px;
    }

    .nav-pill{
      padding:8px 14px;
      border-radius:999px;
      border:1px solid #d6e1ff;
      background:#fff;
      color:#111;
      text-decoration:none;
      font-size:14px;
    }

    .nav-pill:hover{
      background:#f3f6ff;
    }

    h1{
      font-size:clamp(34px,5vw,54px);
      margin:0 0 10px;
      letter-spacing:-.02em;
    }

    .subtitle{
      font-size:18px;
      line-height:1.55;
      color:var(--muted);
      max-width:70ch;
      margin:0;
    }

    .hero{
      margin-top:24px;
      border:1px solid var(--border);
      border-radius:var(--radius);
      overflow:hidden;
      box-shadow:var(--shadow);
      background:#fff;
    }

    .hero img{
      width:100%;
      max-height:620px;
      object-fit:contain;
      display:block;
      background:#f3f4f6;
    }

    .caption{
      padding:12px 16px 16px;
      font-size:14px;
      line-height:1.5;
      color:var(--muted);
      border-top:1px solid var(--border);
      background:#fff;
    }

    .meta-card,
    .text-card,
    .sources-card{
      margin-top:24px;
      border:1px solid var(--border);
      border-radius:var(--radius);
      background:#fff;
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .card-head{
      padding:16px 18px;
      border-bottom:1px solid var(--border);
      background:#fff;
    }

    .card-head h2{
      margin:0;
      font-size:22px;
    }

    .card-body{
      padding:18px;
    }

    .meta-grid{
      display:grid;
      grid-template-columns:180px 1fr;
      gap:12px 18px;
    }

    .meta-label{
      font-size:13px;
      letter-spacing:.04em;
      text-transform:uppercase;
      color:#6b7280;
      font-weight:700;
    }

    .meta-value{
      font-size:16px;
      line-height:1.6;
      color:#111;
    }

    .card-body p{
      margin:0 0 14px;
      font-size:16px;
      line-height:1.7;
      color:#1f2937;
    }

    .card-body p:last-child{
      margin-bottom:0;
    }

    .sources-card ul{
      margin:0;
      padding-left:20px;
    }

    .sources-card li{
      font-size:16px;
      line-height:1.7;
      color:#1f2937;
    }

    footer{
      margin-top:30px;
      padding-top:16px;
      border-top:1px solid var(--border);
      color:var(--muted);
      font-size:14px;
    }

    @media (max-width:700px){
      .meta-grid{
        grid-template-columns:1fr;
        gap:6px 0;
      }
    }
  </style>
</head>

<body>
  <main class="wrap">
    <nav class="nav-pills" aria-label="Site navigation">
      <a class="nav-pill" href="../../index.html">Catalogue home</a>
